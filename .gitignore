# env files (can opt-in for committing if needed)
.env*
!.env.example
release-manifest.json

# Python bytecode
__pycache__/
*.pyc

# Project-local skills venv (regenerable via .claude/scripts/requirements.txt + install.sh)
.claude/skills/.venv/

# Hook crash/runtime logs (ck hook-logger output — churns every session)
.claude/hooks/.logs/

# Runtime artifacts (derived state, regenerated each session)
.claude/session-state/compact-digest.json

# Telemetry sink (.claude/telemetry/) — SELECTIVE: ephemeral observability is
# ignored; persistent streams (instincts, *-events, growth-signals, audits) are
# COMMITTED so they survive across sessions/machines (cross-machine memory + audit).
.claude/telemetry/invocations.jsonl
.claude/telemetry/script-telemetry.jsonl
.claude/telemetry/hook-telemetry.jsonl
.claude/telemetry/errors.jsonl
.claude/telemetry/sessions.jsonl
.claude/telemetry/observations.jsonl
.claude/telemetry/*.jsonl.bak
