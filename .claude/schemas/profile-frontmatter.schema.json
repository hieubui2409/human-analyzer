{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "profile-frontmatter.schema.json",
  "title": "Universal Profile Frontmatter",
  "description": "Authoritative Draft-7 contract for every docs/profiles/**/*.md frontmatter. Reverse-derived from the live corpus (82 files) + universal-profile-schema.yaml (now non-authoritative). additionalProperties:true tolerates per-file extras (llm_summary, period, relationship, established, characters on network/dyad files).",
  "type": "object",
  "required": [
    "character", "domain", "type", "tags", "references",
    "cross_characters", "last_updated", "updated_by", "confidence"
  ],
  "properties": {
    "character": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "domain": {
      "type": "string",
      "enum": ["root", "identity", "psychology", "relationships",
               "timeline", "darkness", "light", "evidence", "growth"]
    },
    "type": { "type": "string", "enum": ["analysis", "narrative", "data", "index", "snapshot"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "references": { "type": "array", "items": { "type": "string" } },
    "cross_characters": { "type": "array", "items": { "type": "string" } },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated_by": { "type": "string", "minLength": 1 },
    "confidence": { "type": "string", "enum": ["high", "medium", "low", "unverified"] },
    "llm_summary": { "type": "string" },
    "period": { "type": "string" }
  },
  "additionalProperties": true
}
